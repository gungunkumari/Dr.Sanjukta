{
  "version": 2,
  "rewrites": [
    {
      "source": "/portal",
      "destination": "/portal.html"
    },
    {
      "source": "/appointment",
      "destination": "/api/index.js"
    },
    {
      "source": "/appointments",
      "destination": "/api/index.js"
    },
    {
      "source": "/appointments/:path*",
      "destination": "/api/index.js"
    }
  ]
}