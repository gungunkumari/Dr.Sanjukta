{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "portal.html",
      "use": "@vercel/static"
    }
  ],

  "routes": [
    {
      "src": "/appointment",
      "methods": ["POST"],
      "dest": "/api/index.js"
    },

    {
      "src": "/appointments",
      "dest": "/api/index.js"
    },

    {
      "src": "/appointments/(.*)",
      "dest": "/api/index.js"
    },

    {
      "src": "/portal",
      "dest": "/portal.html"
    },

    {
      "src": "^/$",
      "dest": "/public/index.html"
    },

    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}